  "keyFeatures": [
    "Power mode control (Quiet, Balance, Performance, Custom/God Mode) with fan curve customization",
    "Battery management with Conservation, Normal, and Rapid Charge modes",
    "Hybrid GPU mode and dGPU management (activate/deactivate, overclock)",
    "Spectrum per-key RGB and 4-zone RGB keyboard backlight control",
    "Automation pipelines with 30+ triggers and 40+ action steps",
    "CLI interface for scripting and integration",
    "No background services — minimal resource usage, no telemetry",
    "Driver and software update checker",
    "Disable/enable Lenovo Vantage, Legion Zone, and Hotkeys without uninstalling"
  ],
  "publicApiSurface": [
    "llt quickAction --list",
    "llt quickAction <name>",
    "llt feature --list",
    "llt feature get <name>",
    "llt feature set <name> <value>",
    "llt spectrum profile get/set <profile>",
    "llt spectrum brightness get/set <brightness>",
    "llt rgb get/set <preset>",
    "PowerModeState (Quiet, Balance, Performance, GodMode)",
    "BatteryState (Conservation, Normal, RapidCharge)",
    "HybridModeState (On, OnIGPUOnly, OnAuto, Off)",
    "AutomationPipeline with triggers and steps"
